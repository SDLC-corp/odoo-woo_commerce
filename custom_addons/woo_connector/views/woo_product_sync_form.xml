<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_woo_product_sync_form" model="ir.ui.view">
        <field name="name">woo.product.sync.form</field>
        <field name="model">woo.product.sync</field>
        <field name="arch" type="xml">
            <form create="false" edit="true" delete="false">
                <header>
                    <button name="action_pull_from_woo"
                            type="object"
                            string="Pull from WooCommerce"
                            class="btn-secondary"/>
                    <button name="action_push_to_woo"
                            type="object"
                            string="Push to WooCommerce"
                            class="btn-primary"/>
                    <button name="action_open_in_woocommerce"
                            type="object"
                            string="Open in WooCommerce"
                            class="btn-secondary"
                            invisible="not woo_product_id"/>
                    <button name="action_ai_generate_description"
                            type="object"
                            string="Generate Description"
                            class="btn-secondary"/>
                    <button name="action_ai_generate_short_description"
                            type="object"
                            string="Generate Short Description"
                            class="btn-secondary"/>
                    <button name="action_ai_improve_seo_text"
                            type="object"
                            string="Improve SEO Text"
                            class="btn-secondary"/>
                    <button name="action_ai_suggest_tags"
                            type="object"
                            string="Suggest Tags"
                            class="btn-secondary"/>
                </header>

                <sheet>
                    <group>
                        <field name="product_tmpl_id"
                               widget="many2one"
                               options="{'no_create': false, 'no_open': false}"/>
                        <field name="instance_id"/>
                        <field name="name"/>
                        <field name="sku"/>
                        <field name="woo_product_id"/>
                        <field name="state"/>
                        <field name="synced_on"/>
                    </group>
                    <group string="Pricing">
                        <field name="list_price"/>
                        <field name="sale_price"/>
                    </group>
                    <group string="Inventory">
                        <field name="manage_stock"/>
                        <field name="qty_available"/>
                        <field name="stock_status"/>
                    </group>
                    <group string="Classification">
                        <field name="category_ids" widget="many2many_tags"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                    <group string="AI Assistant">
                        <field name="ai_content_last_generated" readonly="1"/>
                        <field name="seo_title"/>
                        <field name="seo_description"/>
                        <field name="short_description"/>
                        <field name="description" widget="html"/>
                    </group>
                </sheet>

            </form>
        </field>
    </record>

</odoo>
