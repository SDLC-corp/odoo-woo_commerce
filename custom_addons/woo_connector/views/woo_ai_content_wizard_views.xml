<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_woo_ai_content_wizard_form" model="ir.ui.view">
        <field name="name">woo.ai.content.wizard.form</field>
        <field name="model">woo.ai.content.wizard</field>
        <field name="arch" type="xml">
            <form string="AI Product Content Assistant" create="false" edit="true">
                <header>
                    <button name="action_generate_preview" type="object" string="Regenerate" class="btn-primary"/>
                    <button name="action_apply_to_product" type="object" string="Apply to Product" class="btn-secondary"/>
                    <button string="Close" special="cancel" class="btn-link"/>
                </header>
                <sheet>
                    <group>
                        <field name="product_sync_id" readonly="1"/>
                        <field name="generation_type"/>
                        <field name="tone"/>
                        <field name="seo_mode"/>
                        <field name="status" readonly="1"/>
                        <field name="generated_at" readonly="1"/>
                    </group>
                    <group>
                        <field name="error_message" readonly="1" invisible="not error_message"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="generated_long_description" widget="html"/>
                        </page>
                        <page string="Short Description">
                            <field name="generated_short_description"/>
                        </page>
                        <page string="SEO">
                            <group>
                                <field name="generated_seo_title"/>
                                <field name="generated_seo_description"/>
                            </group>
                        </page>
                        <page string="Tags">
                            <field name="generated_tags_text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
