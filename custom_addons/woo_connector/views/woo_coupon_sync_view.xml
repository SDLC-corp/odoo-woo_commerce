<odoo>

    <record id="woo_coupon_sync_list" model="ir.ui.view">
        <field name="name">woo.coupon.sync.list</field>
        <field name="model">woo.coupon.sync</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="discount_type"/>
                <field name="amount"/>
                <field name="usage_limit"/>
                <field name="usage_count"/>
                <field name="expiry_date"/>
                <field name="status"/>
                <field name="synced_on"/>
            </list>
        </field>
    </record>

    <record id="woo_coupon_sync_form" model="ir.ui.view">
        <field name="name">woo.coupon.sync.form</field>
        <field name="model">woo.coupon.sync</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Coupon">
                <header>
                    <button name="action_push_to_woo"
                            type="object"
                            string="Create / Update in WooCommerce"
                            class="btn-primary"/>
                    <button name="action_pull_from_woo"
                            type="object"
                            string="Pull from WooCommerce"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="discount_type"/>
                        <field name="amount"/>
                        <field name="usage_limit"/>
                        <field name="usage_count"/>
                        <field name="expiry_date"/>
                        <field name="status"/>
                        <field name="synced_on" readonly="1"/>
                        <field name="instance_id"/>
                        <field name="woo_coupon_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
