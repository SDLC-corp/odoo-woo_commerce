<odoo>
    <record id="view_woo_inventory_list" model="ir.ui.view">
        <field name="name">woo.inventory.list</field>
        <field name="model">woo.inventory</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_refresh_inventory"
                            type="object"
                            string="Refresh Inventory"
                            class="btn-primary"/>
                </header>
                <field name="product_name"/>
                <field name="sku"/>
                <field name="quantity"/>
                <field name="stock_status"/>
            </list>
        </field>
    </record>
</odoo>
